# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Run artifacts (per CLAUDE.md)
results/
logs/

# Benchmark datasets fetched on demand by loaders go under data/, but the
# data/briefs/ subfolder holds hand-authored domain briefs that MUST be tracked.
# Use data/* (not data/) so that re-include patterns work — gitignore cannot
# re-include a file under an excluded parent directory.
data/*
!data/briefs/
